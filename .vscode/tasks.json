{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "air: live reload",
      "type": "shell",
      "command": "air",
      "args": ["-c", ".air.toml"],
      "isBackground": true,
      "options": {
        "env": {
          "GOCACHE": "${workspaceFolder}/tmp/go-build"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "go: run",
      "type": "shell",
      "command": "go",
      "args": ["run", "-buildvcs=false", "."],
      "options": {
        "env": {
          "GOCACHE": "${workspaceFolder}/tmp/go-build"
        }
      },
      "problemMatcher": "$go"
    }
  ]
}
